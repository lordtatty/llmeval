# Claude Code harness state (per-session conversation data, never for git)
.claude/

# Working-notes / scratchpad — kept locally, not shipped.
# Anything in notes/ stays out of the repo by default.
notes/

# Go test artifacts
*.test
*.out
coverage.html

# Go workspace — per-developer convenience for editing multiple sub-modules
# together. Each module is independently versioned with its own go.sum, so
# the workspace is not part of the build-of-record.
go.work
go.work.sum

# Local API keys for live LLM tests (`-tags=llmlive`). Never commit these.
# See .env.example for the expected keys.
.env
.env.local

# Editor / OS noise
.DS_Store
.idea/
.vscode/
